---
// Prezzi.astro - Listino Prezzi Interattivo (Senza pulsanti di acquisto nelle card)
---

<section class="prezzi-section" id="prezzi">
  <div class="prezzi-header">
    <p class="section-badge">Tariffe Trasparenti</p>
    <h2 class="section-title">Scegli la tua <span class="highlight-text">durata</span></h2>
    <p class="section-subtitle">
      Soluzioni flessibili per ogni tipo di avventura. Più a lungo pedali, più risparmi. Casco e assicurazione RC sono sempre inclusi nel prezzo.
    </p>
  </div>

  <!-- SISTEMA DI TAB SWITCHER STRUTTURATO SU 4 CATEGORIE -->
  <div class="tab-container">
    <div class="tab-nav" role="tablist">
      <button class="tab-btn active" data-target="breve">Breve Termine</button>
      <button class="tab-btn" data-target="weekend">Weekend & Festivi</button>
      <button class="tab-btn" data-target="lungo">Lungo Termine</button>
      <button class="tab-btn" data-target="stagionale">Stagionali</button>
    </div>

    <div class="tab-content-wrapper">
      
      <!-- TAB 1: BREVE TERMINE -->
      <div class="tab-pane active" id="breve">
        <div class="cards-grid">
          <div class="price-card">
            <span class="card-badge">Ideale pausa pranzo</span>
            <h3>Mezza Giornata</h3>
            <p class="duration">Massimo 4 ore (Escluso Sabato, Domenica e Festivi)</p>
            <div class="price-value">
              <span class="currency">€</span>
              <span class="amount">25</span>
            </div>
            <ul class="features-list">
              <li>Batteria carica al 100%</li>
              <li>Lucchetto e Casco inclusi</li>
            </ul>
          </div>

          <div class="price-card featured">
            <span class="card-badge primary">Il più richiesto</span>
            <h3>Giornata Intera</h3>
            <p class="duration">Fino a 24 ore di libertà</p>
            <div class="price-value">
              <span class="currency">€</span>
              <span class="amount">35</span>
            </div>
            <ul class="features-list">
              <li>Batteria carica al 100%</li>
              <li>Lucchetto e Casco inclusi</li>
              <li>Kit Fast Repair sottosella</li>
              <li>Assistenza tecnica sul percorso</li>
            </ul>
          </div>
        </div>
      </div>

      <!-- TAB 2: WEEKEND & FESTIVI -->
      <div class="tab-pane" id="weekend">
        <div class="cards-grid">
          <div class="price-card">
            <span class="card-badge">Domenica in sella</span>
            <h3>Domenica</h3>
            <p class="duration">Intera giornata festiva</p>
            <div class="price-value">
              <span class="currency">€</span>
              <span class="amount">40</span>
            </div>
            <ul class="features-list">
              <li>Pacchetto Giornata Intera</li>
              <li>Ritiro e consegna flessibili</li>
              <li>Itinerari dedicati della Lessinia</li>
            </ul>
          </div>

          <div class="price-card featured">
            <span class="card-badge primary">Fuga weekend</span>
            <h3>Formula Weekend</h3>
            <p class="duration">Tutto il fine settimana</p>
            <div class="price-value">
              <span class="currency">€</span>
              <span class="amount">60</span>
            </div>
            <ul class="features-list">
              <li>Pacchetto Giornata Intera</li>
              <li>Ritiro ottimizzato per il weekend</li>
              <li>Caricabatterie da viaggio incluso</li>
            </ul>
          </div>
        </div>
      </div>

      <!-- TAB 3: LUNGO TERMINE (7 A 30 GIORNI) -->
      <div class="tab-pane" id="lungo">
        <div class="cards-grid">
          <div class="price-card">
            <h3>7 Giorni</h3>
            <p class="duration">Una settimana intera (25€/giorno)</p>
            <div class="price-value">
              <span class="currency">€</span>
              <span class="amount">175</span>
            </div>
            <ul class="features-list">
              <li>Giornata Intera</li>
              <li>Check-up tecnico a metà noleggio</li>
              <li>Caricabatterie rapido domestico</li>
              <li>Sostituzione in caso di guasto</li>
            </ul>
          </div>

          <div class="price-card">
            <h3>14 Giorni</h3>
            <p class="duration">Due settimane (Meno di 17€/giorno)</p>
            <div class="price-value">
              <span class="currency">€</span>
              <span class="amount">225</span>
            </div>
            <ul class="features-list">
              <li>Kit accessori completo incluso</li>
              <li>Manutenzione ordinaria inclusa</li>
              <li>Ideale per vacanze sul territorio</li>
            </ul>
          </div>

          <div class="price-card">
            <h3>21 Giorni</h3>
            <p class="duration">Tre settimane (Meno di 13€/giorno)</p>
            <div class="price-value">
              <span class="currency">€</span>
              <span class="amount">270</span>
            </div>
            <ul class="features-list">
              <li>Pacchetto Giornata Intera</li>
              <li>Assistenza prioritaria garantita</li>
              <li>Kit accessori completo incluso</li>
              <li>Massimo risparmio a lungo termine</li>
            </ul>
          </div>

          <div class="price-card featured">
            <span class="card-badge primary">Senza Pensieri</span>
            <h3>30 Giorni</h3>
            <p class="duration">Un mese completo (Solo 10€/giorno!)</p>
            <div class="price-value">
              <span class="currency">€</span>
              <span class="amount">300</span>
            </div>
            <ul class="features-list">
              <li>Assistenza prioritaria garantita</li>
              <li>Tariffa giornaliera imbattibile</li>
              <li>Perfetto per locals o lunghi soggiorni</li>
              <li>Supporto tecnico totale incluso</li>
            </ul>
          </div>
        </div>
      </div>

      <!-- TAB 4: ABBONAMENTI STAGIONALI -->
      <div class="tab-pane" id="stagionale">
        <div class="cards-grid">
          <div class="price-card">
            <span class="card-badge">Stagione d'Oro</span>
            <h3>Abbonamento 3 Mesi</h3>
            <p class="duration">Fatturato mensilmente</p>
            <div class="price-value">
              <span class="currency">€</span>
              <span class="amount">250</span>
              <span class="per-month">/mese</span>
            </div>
            <ul class="features-list">
              <li>Assistenza prioritaria garantita</li>
              <li>Tariffa giornaliera imbattibile</li>
              <li>Supporto tecnico totale incluso</li>
              <li>E-bike riservata per 90 giorni</li>
            </ul>
          </div>

          <div class="price-card featured">
            <span class="card-badge primary">Massima Libertà</span>
            <h3>Abbonamento 6 Mesi</h3>
            <p class="duration">La stagione completa delle e-bike</p>
            <div class="price-value">
              <span class="currency">€</span>
              <span class="amount">180</span>
              <span class="per-month">/mese</span>
            </div>
            <ul class="features-list">
              <li>La tua e-bike personale per 6 mesi</li>
              <li>Meno di 6€ al giorno!</li>
              <li>Check-up completi inclusi nella tariffa</li>
            </ul>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  function initPrezziTabs() {
    const tabs = document.querySelectorAll('.tab-btn');
    const panes = document.querySelectorAll('.tab-pane');

    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const target = tab.getAttribute('data-target');

        tabs.forEach(t => t.classList.remove('active'));
        panes.forEach(p => p.classList.remove('active'));

        tab.classList.add('active');
        const activePane = document.getElementById(target);
        if (activePane) activePane.classList.add('active');
      });
    });
  }

  document.addEventListener('DOMContentLoaded', initPrezziTabs);
  document.addEventListener('astro:page-load', initPrezziTabs);
</script>

<style>
  /* ==========================================
     STRUTTURA SEZIONE PREZZI ACCOGLIENTE
     ========================================== */
  .prezzi-section {
    width: 100%;
    background-color: #f4f3ef;
    color: #1a1a1a;
    padding: 120px 40px;
    font-family: 'Plus Jakarta Sans', sans-serif;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 60px;
    position: relative;
    z-index: 20;
  }

  .prezzi-header {
    text-align: center;
    max-width: 800px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .section-badge {
    color: #1a1a1a;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    font-weight: 700;
    margin: 0 0 20px 0;
    border: 1px solid rgba(0,0,0,0.15);
    padding: 6px 14px;
    border-radius: 50px;
    background: rgba(0,0,0,0.02);
  }

  .section-title {
    font-size: 3.5rem;
    font-weight: 600;
    line-height: 1.1;
    margin: 0 0 25px 0;
    letter-spacing: -0.04em;
  }

  .highlight-text {
    color: #111;
    font-weight: 400;
    font-style: italic;
    text-decoration: underline;
    text-decoration-color: #dbff9b;
    text-decoration-thickness: 5px;
  }

  .section-subtitle {
    font-size: 1.1rem;
    line-height: 1.6;
    color: #555;
    margin: 0;
  }

  /* ==========================================
     SISTEMA DEI NAV TAB (SWITCHER)
     ========================================== */
  .tab-container {
    width: 100%;
    max-width: 1200px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 40px;
  }

  .tab-nav {
    background: rgba(0, 0, 0, 0.04);
    padding: 6px;
    border-radius: 50px;
    display: flex;
    gap: 5px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .tab-btn {
    background: transparent;
    border: none;
    padding: 12px 26px;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 0.9rem;
    font-weight: 600;
    color: #555;
    border-radius: 50px;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .tab-btn.active {
    background: #111111;
    color: #dbff9b;
    box-shadow: 0 10px 25px rgba(0,0,0,0.08);
  }

  .tab-content-wrapper {
    width: 100%;
  }

  .tab-pane {
    display: none;
    width: 100%;
  }

  .tab-pane.active {
    display: block;
    animation: fadeIn 0.45s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* ==========================================
     GRIGLIA DELLE CARD PREZZO
     ========================================== */
  .cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 25px;
    width: 100%;
    justify-content: center;
  }

  /* LA SINGOLA CARD */
  .price-card {
    background: #ffffff;
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: 24px;
    padding: 40px 30px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    position: relative;
    box-shadow: 0 10px 30px rgba(0,0,0,0.01);
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.4s ease;
  }

  .price-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 20px 45px rgba(0,0,0,0.06);
  }

  .price-card.featured {
    background: #111111;
    color: #ffffff;
    border: none;
    box-shadow: 0 15px 35px rgba(0,0,0,0.12);
  }

  .card-badge {
    font-size: 0.7rem;
    text-transform: uppercase;
    font-weight: 700;
    letter-spacing: 1px;
    color: #666;
    background: rgba(0,0,0,0.04);
    padding: 4px 12px;
    border-radius: 50px;
    margin-bottom: 20px;
  }

  .card-badge.primary {
    color: #111111;
    background: #dbff9b;
  }

  .price-card h3 {
    font-size: 1.5rem;
    font-weight: 600;
    margin: 0 0 6px 0;
    letter-spacing: -0.02em;
  }

  .duration {
    font-size: 0.85rem;
    color: #666;
    margin: 0 0 25px 0;
  }

  .price-card.featured .duration {
    color: #999;
  }

  /* BLOCCO VALORE PREZZO */
  .price-value {
    display: flex;
    align-items: flex-start;
    gap: 3px;
    margin-bottom: 25px;
  }

  .currency {
    font-size: 1.3rem;
    font-weight: 600;
    margin-top: 4px;
  }

  .amount {
    font-size: 3.5rem;
    font-weight: 700;
    line-height: 0.9;
    letter-spacing: -0.04em;
  }

  .per-month {
    align-self: flex-end;
    font-size: 1rem;
    color: #666;
    margin-left: 2px;
    font-weight: 500;
  }

  .price-card.featured .per-month {
    color: #999;
  }

  /* LISTA DELLE CARATTERISTICHE */
  .features-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
    width: 100%;
    border-top: 1px solid rgba(0,0,0,0.06);
    padding-top: 20px;
  }

  .price-card.featured .features-list {
    border-top: 1px solid rgba(255,255,255,0.08);
  }

  .features-list li {
    font-size: 0.9rem;
    color: #444;
    display: flex;
    align-items: flex-start;
    gap: 10px;
    line-height: 1.4;
  }

  .features-list li::before {
    content: "✓";
    color: #111111;
    font-weight: 700;
    flex-shrink: 0;
  }

  .price-card.featured .features-list li {
    color: #cccccc;
  }

  .price-card.featured .features-list li::before {
    color: #dbff9b;
  }

  /* ==========================================
     RESPONSIVE DI PRECISIONE
     ========================================== */
  @media (max-width: 1024px) {
    .prezzi-section { padding: 80px 30px; gap: 45px; }
    .section-title { font-size: 2.8rem; }
    .cards-grid { grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 20px; }
  }

  @media (max-width: 768px) {
    .prezzi-section { padding: 60px 20px; gap: 35px; }
    .section-title { font-size: 2.2rem; }
    .tab-nav { width: 100%; flex-direction: column; border-radius: 20px; padding: 6px; }
    .tab-btn { width: 100%; text-align: center; padding: 10px; }
    .cards-grid { grid-template-columns: 1fr; }
  }
</style>