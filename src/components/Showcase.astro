---
// Showcase.astro - Lookbook con Hotspot, Card fisse, Annotazioni Handwritten e Icone Alpine
import showcaseBike1 from '../images/ebike1.png';
import cambioBike from '../images/cambio.jpg';
import contakmBike from '../images/contakm.jpg';
import manubrioBike from '../images/manubrio.jpg';
import telaioBike from '../images/telaio.jpg';
---

<div class="showcase-sticky-container" id="showcase">
  <div class="showcase-zoom-wrapper">
    <section class="lookbook-section">
      <div class="header-content">
        <h2 class="main-title reveal-word italic-title shimmer-effect">X-plör Venture</h2>
        <p class="subtitle">Il nostro modello di punta combina eleganza e prestazioni estreme. Con un’autonomia fino a 100km e un motore ultra-silenzioso, la Venture Salvia è la compagna perfetta per le tue esplorazioni quotidiane.</p>
      </div>

      <div class="visual-container">
        
        <div class="ebike-interactive-wrapper">
          <img src={showcaseBike1.src} alt="E-MTB Model" class="hero-img" />

          <div class="hotspot-point" style="top: 30%; left: 48%;">
            <button class="hotspot-trigger" aria-label="Info Motore">+</button>
            <div class="hotspot-popup pop-left">
              <div class="popup-thumb">
                <img src={telaioBike.src} alt="Telaio Tech" />
              </div>
              <div class="popup-content">
                <h3>Telaio</h3>
                <p>Costruito con materials avanzati per massima resistenza e leggerezza.</p>
              </div>
            </div>
          </div>

          <div class="hotspot-point" style="top: 15%; left: 65%;">
            <button class="hotspot-trigger" aria-label="Info Batteria">+</button>
            <div class="hotspot-popup pop-top">
              <div class="popup-thumb">
                <img src={contakmBike.src} alt="Display Digtale" />
              </div>
              <div class="popup-content">
                <h3>Display Digtale</h3>
                <p>Monitoraggio preciso della distanza percorsa con display digital.</p>
              </div>
            </div>
          </div>

          <div class="hotspot-point" style="top: 70%; left: 15%;">
            <button class="hotspot-trigger" aria-label="Info Freni">+</button>
            <div class="hotspot-popup pop-right">
              <div class="popup-thumb">
                <img src={cambioBike.src} alt="Cambio Tech" />
              </div>
              <div class="popup-content">
                <h3>Cambio</h3>
                <p>Cambio 12 velocità con sistema di cambio automatico.</p>
              </div>
            </div>
          </div>

          <div class="hotspot-point" style="top: 30%; left: 70%;">
            <button class="hotspot-trigger" aria-label="Info Sospensioni">+</button>
            <div class="hotspot-popup pop-left">
              <div class="popup-thumb">
                <img src={manubrioBike.src} alt="Manubrio Tech" />
              </div>
              <div class="popup-content">
                <h3>Manubrio</h3>
                <p>Progettato per comfort e controllo ottimale in ogni condizione di guida.</p>
              </div>
            </div>
          </div>
        </div>

        <div class="cards-responsive-container">
          
          <div class="feature-card card-left-top">
            <div class="card-icon-box">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                <path d="M4 22L12 10L20 22H4Z" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M10 22L14 15L18 22" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M12 4V2M12 2L9 5M12 2L15 5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <div class="card-text">
              <h3>Power Performance</h3>
              <p>Motore centrale da 85Nm per scalate senza compromessi su ogni terreno.</p>
            </div>
          </div>

          <div class="feature-card card-right-top">
            <div class="card-icon-box">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                <path d="M13 2L3 14H12L11 22L21 10H12L13 2Z" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <div class="card-text">
              <h3>Endurance Battery</h3>
              <p>630Wh di pura energia per avventure che durano tutto il giorno.</p>
            </div>
          </div>

          <div class="feature-card card-left-bottom">
            <div class="card-icon-box">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                <path d="M12 22C12 22 20 18 20 12V5L12 2L4 5V12C4 18 12 22 12 22Z" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <div class="card-text">
              <h3>Hydraulic Control</h3>
              <p>Freni a disco idraulici a 4 pistoncini per frenate millimetriche in discesa.</p>
            </div>
          </div>

          <div class="feature-card card-right-mid">
            <div class="card-icon-box">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                <path d="M12 20V4M12 4L8 8M12 4L16 8M6 20H18" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <div class="card-text">
              <h3>Smart Suspension</h3>
              <p>Forcella anteriore ad aria con 140mm di escursione e blocco remoto.</p>
            </div>
          </div>

        </div>

        <div class="notebook-annotation note-top-left">
          <span class="handwritten">Testata sui tornanti delle Lessini</span>
          <svg class="handwritten-arrow" width="60" height="40" viewBox="0 0 80 40">
            <path d="M10,10 Q40,35 70,15 M60,10 L70,15 L65,25" fill="none" stroke="#1a1a1a" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </div>

        <div class="notebook-annotation note-bottom-right">
          <svg class="handwritten-arrow arrow-invert" width="50" height="40" viewBox="0 0 80 40">
            <path d="M70,10 Q40,35 10,15 M20,10 L10,15 L15,25" fill="none" stroke="#1a1a1a" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          <span class="handwritten">Grip estremo da fango e roccia</span>
        </div>

      </div>

      <div class="action-cta">
        <a href="#contatti" class="btn-main">Prenota Ora!</a>
      </div>
    </section>
  </div>
</div>

<script>
  function initShowcaseObserver() {
    const showcaseSection = document.getElementById('showcase');

    if (showcaseSection) {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target); 
          }
        });
      }, {
        threshold: 0.1, 
        rootMargin: '0px 0px -40px 0px'
      });
      observer.observe(showcaseSection);
    }
  }

  document.addEventListener('DOMContentLoaded', initShowcaseObserver);
  document.addEventListener('astro:page-load', initShowcaseObserver);
</script>

<style>
  /* ==========================================
     CONTENITORE ESTERNO: GESTISCE LO STICKY PURO
     ========================================== */
  .showcase-sticky-container {
    width: 100%;
    position: sticky;
    top: 0;
    height: 100dvh;
    z-index: 1;
    overflow: hidden;
    margin-bottom: 70px;
  }

  /* ==========================================
     CONTENITORE INTERNO: ZOOM IN INGRESSO PROTETTO
     ========================================== */
  .showcase-zoom-wrapper {
    width: 100%;
    height: 100%;
    background-color: #D8D5CD; 
    opacity: 0;
    transform: scale(0.85); 
    transition: transform 1.4s cubic-bezier(0.16, 1, 0.3, 1), opacity 1.2s ease-out;
    will-change: transform, opacity;
  }

  .showcase-sticky-container.is-visible .showcase-zoom-wrapper {
    opacity: 1;
    transform: scale(1); 
  }

  .lookbook-section {
    height: 100%;
    padding: 60px 40px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: space-between;
    position: relative;
    font-family: 'Plus Jakarta Sans', sans-serif;
    color: #1a1a1a;
  }

  .header-content {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
  }

  .main-title {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 600;
    margin: 0;
    letter-spacing: -0.04em;
  }

  .subtitle {
    font-size: clamp(1.1rem, 2.5vw, 1.3rem);
    color: #444;
    text-align: center;
    max-width: 600px;
    margin: 12px auto 0 auto;
  }

  .visual-container {
    position: relative;
    width: 100%;
    max-width: 1400px;
    height: 750px;
    display: flex;
    justify-content: center;
    align-items: center;
    margin: auto 0;
  }

  /* ==========================================
     STRUTTURA CELLULA BICI CENTRALE
     ========================================== */
  .ebike-interactive-wrapper {
    position: relative;
    width: 100%;
    max-width: 650px; 
    z-index: 2;
  }

  .hero-img {
    width: 100%;
    height: auto;
    display: block;
    filter: drop-shadow(0 40px 60px rgba(0,0,0,0.12));
  }

  /* ==========================================
     SISTEMA HOTSPOT SULLA BICI
     ========================================== */
  .hotspot-point {
    position: absolute;
    z-index: 10; /* Livello desktop normale */
  }

  /* FIX CRITICO DESKTOP: Quando passi sull'hotspot, il padre sale di livello */
  .hotspot-point:hover {
    z-index: 100;
  }

  .hotspot-trigger {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    border: none;
    background: #111111;
    color: #ffffff;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 0 0 0 rgba(17, 17, 17, 0.4);
    transition: transform 0.3s ease, background-color 0.3s ease;
    animation: pulseGlow 2s infinite;
  }

  @keyframes pulseGlow {
    0% { box-shadow: 0 0 0 0 rgba(17, 17, 17, 0.5); }
    70% { box-shadow: 0 0 0 10px rgba(17, 17, 17, 0); }
    100% { box-shadow: 0 0 0 0 rgba(17, 17, 17, 0); }
  }

  .hotspot-trigger:hover {
    background: #dbff9b;
    transform: scale(1.15) rotate(45deg);
  }

  .hotspot-popup {
    position: absolute;
    background: #ffffff;
    border-radius: 16px;
    width: 240px;
    overflow: hidden;
    box-shadow: 0 20px 45px rgba(0,0,0,0.18);
    opacity: 0;
    visibility: hidden;
    transform: scale(0.9) translateY(10px);
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    pointer-events: none;
  }

  .hotspot-point:hover .hotspot-popup {
    opacity: 1;
    visibility: visible;
    transform: scale(1) translateY(0);
    pointer-events: auto;
  }

  .popup-thumb { width: 100%; height: 120px; overflow: hidden; }
  .popup-thumb img { width: 100%; height: 100%; object-fit: cover; }
  .popup-content { padding: 12px;}
  .popup-content h3 { font-size: 1rem; margin: 0 0 4px 0; font-weight: 700; color: #111; }
  .popup-content p { font-size: 0.8rem; color: #666; line-height: 1.4; margin: 0; }

  .pop-left  { right: 35px; top: -40px; transform-origin: right center; }
  .pop-right { left: 35px; top: -40px; transform-origin: left center; }
  .pop-top   { bottom: 35px; left: -106px; transform-origin: center bottom; }

  /* ==========================================
     LIVELLO DELLE 4 MINI CARD CON ICONE
     ========================================== */
  .cards-responsive-container {
    position: absolute;
    width: 100%;
    height: 100%;
    top: 0;
    left: 0;
    pointer-events: none; 
  }

  .feature-card {
    position: absolute;
    background: #ffffff;
    border-radius: 20px;
    padding: 20px;
    width: 340px;
    display: flex;
    align-items: flex-start;
    gap: 18px;
    box-shadow: 0 15px 35px rgba(0,0,0,0.05);
    z-index: 20;
    pointer-events: auto; 
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    cursor: pointer;
    animation: float 6s ease-in-out infinite;
    box-sizing: border-box;
  }

  .feature-card:hover {
    transform: translateY(-10px) scale(1.02);
    box-shadow: 0 25px 50px rgba(0,0,0,0.08);
  }

  .card-icon-box {
    width: 48px;
    height: 48px;
    background: #f4f3ef;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #111111;
    flex-shrink: 0;
    transition: background-color 0.3s, color 0.3s;
  }

  .feature-card:hover .card-icon-box {
    background: #111111;
    color: #ffffff;
  }

  .card-icon-box svg {
    width: 24px;
    height: 24px;
  }

  .card-text h3 { font-size: 1.1rem; margin: 0; font-weight: 600; color: #1a1a1a; }
  .card-text p { font-size: 0.85rem; color: #555; margin: 6px 0 0; line-height: 1.4; }

  .card-left-top     { left: 0;   top: 8%;   animation-delay: 0s; }
  .card-right-top    { right: 0;  top: 8%;   animation-delay: 1.5s; }
  .card-left-bottom  { left: 40px;  bottom: 8%;  animation-delay: 3s; }
  .card-right-mid    { right: 40px; bottom: 15%; animation-delay: 4.5s; }

  /* ==========================================
     STILI NOTEBOOK ANNOTATIONS (HANDWRITTEN)
     ========================================== */
  .notebook-annotation {
    position: absolute;
    display: flex;
    flex-direction: column;
    align-items: center;
    z-index: 1;
    pointer-events: none;
    opacity: 0.75;
  }

  .handwritten {
    font-family: 'Caveat', cursive;
    font-size: 1.5rem;
    font-weight: 500;
    color: #2c2c2c;
    white-space: nowrap;
    letter-spacing: 0.5px;
  }

  .handwritten-arrow {
    background: none;
  }

  .note-top-left {
    left: 26%;
    top: 15%;
    transform: rotate(-4deg);
  }

  .note-bottom-right {
    right: 25%;
    bottom: 0%;
    transform: rotate(3deg);
  }

  .arrow-invert {
    transform: scaleX(-1);
  }

  .action-cta { margin-top: 40px; z-index: 10; }
  .btn-main {
    display: inline-block;
    background: transparent;
    color: #1a1a1a;
    border: 2px solid #1a1a1a;
    padding: 15px 45px;
    border-radius: 50px;
    font-weight: 700;
    text-decoration: none;
    text-transform: uppercase;
    font-size: 0.9rem;
    transition: all 0.3s ease;
  }
  .btn-main:hover { background: #1a1a1a; color: #fff; transform: translateY(-2px); }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }

  @media (max-width: 1340px) {
    .feature-card { width: 285px; padding: 16px; gap: 14px; }
    .ebike-interactive-wrapper { max-width: 500px; }
    .card-left-bottom { left: 10px; }
    .card-right-mid { right: 10px; }
    .notebook-annotation { display: none !important; }
  }

  /* ==========================================
     RESPONSIVE DI PRECISIONE MOBILE (SOTTO 1024PX)
     ========================================== */
  @media (max-width: 1024px) {
    .showcase-sticky-container {
      position: sticky !important;
      top: 0;
      height: 100dvh !important;
      min-height: 100dvh !important;
    }

    .lookbook-section {
      padding: 40px 20px;
      justify-content: center !important;
      gap: 30px;
    }

    .main-title {
      font-size: 2.5rem !important;
      letter-spacing: -0.03em;
    }

    .subtitle {
      font-size: 0.95rem !important;
      max-width: 100%;
      margin-top: 10px;
    }

    .visual-container {
      height: auto !important;
      flex-direction: column;
      margin: 20px 0;
    }

    .ebike-interactive-wrapper {
      max-width: 100% !important; 
      filter: drop-shadow(0 20px 40px rgba(0,0,0,0.1));
    }

    .hero-img {
      max-height: 280px !important;
      object-fit: contain;
    }

    .cards-responsive-container {
      display: none !important;
    }
    
    .hotspot-point {
      display: block !important; 
      /* 👇 ELEMENTARE: Di base il punto sta sotto, ma se ci va il mouse sopra sale a mille */
      z-index: 10 !important; 
    }

    /* 👇 QUESTO RISOLVE IL TUO BUG DEL VIDEO: 
       Quando l'utente attiva questo specifico hotspot, il suo intero guscio 
       diventa il re incontrastato dello schermo, oscurando gli altri pallini */
    .hotspot-point:hover {
      z-index: 99999 !important;
    }

    /* THE BOTTOM-SHEET POPUP CONTAINER */
    .hotspot-popup {
      top: auto !important;
      left: 5% !important;  /* Centratura millimetrica stabile (5% sx + 5% dx) */
      right: 5% !important; 
      bottom: 20px !important; 
      
      width: 80vw !important; 
      max-width: 400px;
      height: auto !important;
      position: fixed !important; 
      
      border-radius: 20px !important;
      background: rgba(255, 255, 255, 0.98);
      backdrop-filter: blur(10px);
      border: 1px solid rgba(0, 0, 0, 0.05);
      box-shadow: 0 15px 40px rgba(0,0,0,0.25);
      
      transform-origin: center bottom !important;
      transform: translateY(10px) scale(0.98) !important;
      transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1) !important;
      
      /* Forza l'elemento interno a passare sopra a tutto il resto della pagina */
      z-index: 99999 !important; 
    }

    .hotspot-point:hover .hotspot-popup {
      opacity: 1 !important;
      visibility: visible !important;
      transform: translateY(0) scale(1) !important;
    }

    .popup-thumb { 
      height: 120px !important; 
    }
    
    .popup-content { 
      padding: 15px 20px !important; 
      display: flex;
      flex-direction: column;
      gap: 5px;
    }

    .popup-content h3 { font-size: 1.15rem !important; }
    .popup-content p { font-size: 0.9rem !important; line-height: 1.5; color: #555; }

    .action-cta { 
      margin-top: 20px; 
      margin-bottom: 20px;
    }
    .btn-main {
      width: 100%;
      max-width: 300px;
      font-size: 0.85rem;
      padding:20px 60px;
    }
  }

  @media (max-width: 768px) {
    .lookbook-section { padding: 50px 20px; }
    .ebike-interactive-wrapper { max-width: 95%; }
    .hero-img { max-height: 250px; object-fit: contain; }
    .cards-responsive-container { grid-template-columns: 1fr; gap: 16px; }
    .feature-card { padding: 14px; border-radius: 16px; }
  }
</style>