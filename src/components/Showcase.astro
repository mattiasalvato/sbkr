---
// Showcase.astro - Lookbook con Hotspot, Card fisse, Annotazioni Handwritten e Icone Alpine
---

<div class="showcase-scroll-wrapper" id="showcase">
  <section class="lookbook-section">
    <div class="header-content">
      <h2 class="main-title reveal-word italic-title shimmer-effect">X-plör Venture</h2>
      <p class="subtitle">Il nostro modello di punta combina eleganza e prestazioni estreme. Con un’autonomia fino a 100km e un motore ultra-silenzioso, la Venture Salvia è la compagna perfetta per le tue esplorazioni quotidiane.</p>
    </div>

    <div class="visual-container">
      
      <div class="ebike-interactive-wrapper">
        <img src="/images/ebike1.png" alt="E-MTB Model" class="hero-img" />

        <div class="hotspot-point" style="top: 65%; left: 48%;z-index: 50;">
          <button class="hotspot-trigger" aria-label="Info Motore">+</button>
          <div class="hotspot-popup pop-left">
            <div class="popup-thumb">
              <img src="https://placehold.co/300x200/1e293b/fff?text=85Nm+Motor" alt="Motor Tech" />
            </div>
            <div class="popup-content">
              <h3>85Nm Torque</h3>
              <p>Spinta immediata e fluidità di pedalata in pendenza.</p>
            </div>
          </div>
        </div>

        <div class="hotspot-point" style="top: 45%; left: 35%;">
          <button class="hotspot-trigger" aria-label="Info Batteria">+</button>
          <div class="hotspot-popup pop-top">
            <div class="popup-thumb">
              <img src="https://placehold.co/300x200/1e293b/fff?text=630Wh+Battery" alt="Battery Tech" />
            </div>
            <div class="popup-content">
              <h3>Lithium Cells</h3>
              <p>Celle ad alta densità integrate per la massima autonomia.</p>
            </div>
          </div>
        </div>

        <div class="hotspot-point" style="top: 70%; left: 15%;">
          <button class="hotspot-trigger" aria-label="Info Freni">+</button>
          <div class="hotspot-popup pop-right">
            <div class="popup-thumb">
              <img src="https://placehold.co/300x200/1e293b/fff?text=Hydraulic+Brakes" alt="Brakes Tech" />
            </div>
            <div class="popup-content">
              <h3>Magura MT5</h3>
              <p>Impianto idraulico a risonanza ridotta per discese ripide.</p>
            </div>
          </div>
        </div>

        <div class="hotspot-point" style="top: 35%; left: 75%;z-index: 55;">
          <button class="hotspot-trigger" aria-label="Info Sospensioni">+</button>
          <div class="hotspot-popup pop-left">
            <div class="popup-thumb">
              <img src="https://placehold.co/300x200/1e293b/fff?text=140mm+Suspension" alt="Suspension Tech" />
            </div>
            <div class="popup-content">
              <h3>Air Shocks</h3>
              <p>Assorbimento progressivo degli urti su radici e rocce.</p>
            </div>
          </div>
        </div>
      </div>

      <div class="cards-responsive-container">
        
        <div class="feature-card card-left-top">
          <div class="card-icon-box">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
              <path d="M4 22L12 10L20 22H4Z" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M10 22L14 15L18 22" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M12 4V2M12 2L9 5M12 2L15 5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <div class="card-text">
            <h3>Power Performance</h3>
            <p>Motore centrale da 85Nm per scalate senza compromessi su ogni terreno.</p>
          </div>
        </div>

        <div class="feature-card card-right-top">
          <div class="card-icon-box">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
              <path d="M13 2L3 14H12L11 22L21 10H12L13 2Z" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <div class="card-text">
            <h3>Endurance Battery</h3>
            <p>630Wh di pura energia per avventure che durano tutto il giorno.</p>
          </div>
        </div>

        <div class="feature-card card-left-bottom">
          <div class="card-icon-box">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
              <path d="M12 22C12 22 20 18 20 12V5L12 2L4 5V12C4 18 12 22 12 22Z" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <div class="card-text">
            <h3>Hydraulic Control</h3>
            <p>Freni a disco idraulici a 4 pistoncini per frenate millimetriche in discesa.</p>
          </div>
        </div>

        <div class="feature-card card-right-mid">
          <div class="card-icon-box">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
              <path d="M12 20V4M12 4L8 8M12 4L16 8M6 20H18" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <div class="card-text">
            <h3>Smart Suspension</h3>
            <p>Forcella anteriore ad aria con 140mm di escursione e blocco remoto.</p>
          </div>
        </div>

      </div>

      <div class="notebook-annotation note-top-left">
        <span class="handwritten">Testata sui tornanti delle Lessini</span>
        <svg class="handwritten-arrow" width="60" height="40" viewBox="0 0 80 40">
          <path d="M10,10 Q40,35 70,15 M60,10 L70,15 L65,25" fill="none" stroke="#1a1a1a" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </div>

      <div class="notebook-annotation note-bottom-right">
        <svg class="handwritten-arrow arrow-invert" width="50" height="40" viewBox="0 0 80 40">
          <path d="M70,10 Q40,35 10,15 M20,10 L10,15 L15,25" fill="none" stroke="#1a1a1a" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
        <span class="handwritten">Grip estremo da fango e roccia</span>
      </div>

    </div>

    <div class="action-cta">
      <a href="#contatti" class="btn-main">BOOK A TEST RIDE</a>
    </div>
   
  </section>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const showcaseSection = document.getElementById('showcase');

    if (showcaseSection) {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target); 
          }
        });
      }, {
        threshold: 0.1, 
        rootMargin: '0px 0px -40px 0px'
      });
      observer.observe(showcaseSection);
    }
  });
</script>

<style>
  /* ==========================================
     CONTENITORE REGIDO ZOOM IN INGRESSO
     ========================================== */
  .showcase-scroll-wrapper {
    width: 100%;
    background-color: #D8D5CD; 
    opacity: 0;
    transform: scale(0.85); 
    transition: transform 1.4s cubic-bezier(0.16, 1, 0.3, 1), opacity 1.2s ease-out;
    will-change: transform, opacity;
  }

  .showcase-scroll-wrapper.is-visible {
    opacity: 1;
    transform: scale(1); 
  }

  .lookbook-section {
    min-height: 100vh;
    padding: 80px 40px;
    display: flex;
    flex-direction: column;
    align-items: center;
    position: relative;
    font-family: 'Inter', sans-serif;
    color: #1a1a1a;
    overflow: hidden;
  }

  .header-content {
   text-align: center; /* Centra il titolo e gli elementi inline/block */
  display: flex;
  flex-direction: column;
  align-items: center; /* Forza la centratura dei blocchi se usi flex */
  width: 100%;
  }

  .main-title {
    font-family: 'Poppins', sans-serif;
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 600;
    margin: 0;
    letter-spacing: -0.04em;
  }

  .subtitle {
    font-size: clamp(1.1rem, 2.5vw, 1.3rem);
    color: #444;
    text-align: center; /* Centra le righe di testo all'interno del paragrafo */
  max-width: 600px;   /* Evita che la riga diventi troppo lunga e illeggibile */
  margin: 12px auto 0 auto; /* L' 'auto' sui lati centra il blocco del paragrafo */
  }

  .visual-container {
    position: relative;
    width: 100%;
    max-width: 1400px;
    height: 750px;
    display: flex;
    justify-content: center;
    align-items: center;
    margin: auto 0;
  }

  /* ==========================================
     STRUTTURA CELLULA BICI CENTRALE
     ========================================== */
  .ebike-interactive-wrapper {
    position: relative;
    width: 100%;
    max-width: 650px; 
    z-index: 2;
  }

  .hero-img {
    width: 100%;
    height: auto;
    display: block;
    filter: drop-shadow(0 40px 60px rgba(0,0,0,0.12));
  }

  /* ==========================================
     SISTEMA HOTSPOT SULLA BICI
     ========================================== */
  .hotspot-point {
    position: absolute;
    z-index: 30;
  }

  .hotspot-trigger {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    border: none;
    background: #111111;
    color: #ffffff;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 0 0 0 rgba(17, 17, 17, 0.4);
    transition: transform 0.3s ease, background-color 0.3s ease;
    animation: pulseGlow 2s infinite;
  }

  @keyframes pulseGlow {
    0% { box-shadow: 0 0 0 0 rgba(17, 17, 17, 0.5); }
    70% { box-shadow: 0 0 0 10px rgba(17, 17, 17, 0); }
    100% { box-shadow: 0 0 0 0 rgba(17, 17, 17, 0); }
  }

  .hotspot-trigger:hover {
    background: #dbff9b;
    transform: scale(1.15) rotate(45deg);
  }

  .hotspot-popup {
    position: absolute;
    background: #ffffff;
    border-radius: 16px;
    width: 240px;
    overflow: hidden;
    box-shadow: 0 20px 45px rgba(0,0,0,0.18);
    opacity: 0;
    visibility: hidden;
    transform: scale(0.9) translateY(10px);
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    pointer-events: none;
    z-index: 40;
  }

  .hotspot-point:hover .hotspot-popup {
    opacity: 1;
    visibility: visible;
    transform: scale(1) translateY(0);
    pointer-events: auto;
  }

  .popup-thumb { width: 100%; height: 120px; overflow: hidden;}
  .popup-thumb img { width: 100%; height: 100%; object-fit: cover; }
  .popup-content { padding: 12px;}
  .popup-content h3 { font-size: 1rem; margin: 0 0 4px 0; font-weight: 700; color: #111; }
  .popup-content p { font-size: 0.8rem; color: #666; line-height: 1.4; margin: 0; }

  .pop-left  { right: 35px; top: -40px; transform-origin: right center; }
  .pop-right { left: 35px; top: -40px; transform-origin: left center; }
  .pop-top   { bottom: 35px; left: -106px; transform-origin: center bottom; }

  /* ==========================================
     LIVELLO DELLE 4 MINI CARD CON ICONE
     ========================================== */
  .cards-responsive-container {
    position: absolute;
    width: 100%;
    height: 100%;
    top: 0;
    left: 0;
    pointer-events: none; 
  }

  .feature-card {
    position: absolute;
    background: #ffffff;
    border-radius: 20px;
    padding: 20px;
    width: 340px;
    display: flex;
    align-items: flex-start;
    gap: 18px;
    box-shadow: 0 15px 35px rgba(0,0,0,0.05);
    z-index: 20;
    pointer-events: auto; 
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    cursor: pointer;
    animation: float 6s ease-in-out infinite;
    box-sizing: border-box;
  }

  .feature-card:hover {
    transform: translateY(-10px) scale(1.02);
    box-shadow: 0 25px 50px rgba(0,0,0,0.08);
  }

  /* Box Favicon Tecnica Autonoma */
  .card-icon-box {
    width: 48px;
    height: 48px;
    background: #f4f3ef;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #111111;
    flex-shrink: 0;
    transition: background-color 0.3s, color 0.3s;
  }

  .feature-card:hover .card-icon-box {
    background: #111111;
    color: #ffffff;
  }

  .card-icon-box svg {
    width: 24px;
    height: 24px;
  }

  .card-text h3 { font-size: 1.1rem; margin: 0; font-weight: 600; color: #1a1a1a; }
  .card-text p { font-size: 0.85rem; color: #555; margin: 6px 0 0; line-height: 1.4; }

  /* Distribuzione geometrica fissa delle card attorno alla bici */
  .card-left-top     { left: 0;   top: 8%;   animation-delay: 0s; }
  .card-right-top    { right: 0;  top: 8%;   animation-delay: 1.5s; }
  .card-left-bottom  { left: 40px;  bottom: 8%;  animation-delay: 3s; }
  .card-right-mid    { right: 40px; bottom: 15%; animation-delay: 4.5s; }

  /* ==========================================
     STILI NOTEBOOK ANNOTATIONS (HANDWRITTEN)
     ========================================== */
  .notebook-annotation {
    position: absolute;
    display: flex;
    flex-direction: column;
    align-items: center;
    z-index: 5;
    pointer-events: none;
    opacity: 0.75;
  }

  .handwritten {
    font-family: 'Caveat', cursive;
    font-size: 1.5rem;
    font-weight: 500;
    color: #2c2c2c;
    white-space: nowrap;
    letter-spacing: 0.5px;
  }

  .handwritten-arrow {
    background: none;
  }

  .note-top-left {
    left: 26%;
    top: 15%;
    transform: rotate(-4deg);
  }

  .note-bottom-right {
    right: 25%;
    bottom: 12%;
    transform: rotate(3deg);
  }

  .arrow-invert {
    transform: scaleX(-1);
  }

  .action-cta { margin-top: 40px; z-index: 10; }
  .btn-main {
    display: inline-block;
    background: transparent;
    color: #1a1a1a;
    border: 2px solid #1a1a1a;
    padding: 15px 45px;
    border-radius: 50px;
    font-weight: 700;
    text-decoration: none;
    text-transform: uppercase;
    font-size: 0.9rem;
    transition: all 0.3s ease;
  }
  .btn-main:hover { background: #1a1a1a; color: #fff; transform: translateY(-2px); }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }

  /* ==========================================
     MEDIA QUERIES - RESPONSIVE DI PRECISIONE
     ========================================== */
  @media (max-width: 1340px) {
    .feature-card { width: 285px; padding: 16px; gap: 14px; }
    .ebike-interactive-wrapper { max-width: 500px; }
    .card-left-bottom { left: 10px; }
    .card-right-mid { right: 10px; }
    .notebook-annotation { display: none !important; } /* Rimosse sui laptop stretti */
  }

  @media (max-width: 1024px) {
    .showcase-scroll-wrapper { transform: none !important; opacity: 1 !important; }
    .lookbook-section { padding: 60px 24px; min-height: auto; }
    .visual-container { height: auto; flex-direction: column; gap: 50px; margin: 30px 0; }

    .hotspot-point, .notebook-annotation { display: none !important; }
    .ebike-interactive-wrapper { max-width: 75%; order: 1; }
    .hero-img { max-height: 360px; }

    .cards-responsive-container {
      position: relative;
      width: 100%;
      height: auto;
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 20px;
      order: 2;
      pointer-events: auto;
    }

    .feature-card {
      position: relative;
      width: 100% !important;
      left: auto !important;
      right: auto !important;
      top: auto !important;
      bottom: auto !important;
      animation: none !important;
      box-shadow: 0 8px 25px rgba(0,0,0,0.03);
      
      opacity: 0;
      transform: translateY(20px) !important;
      transition: opacity 0.6s cubic-bezier(0.16, 1, 0.3, 1), transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .showcase-scroll-wrapper.is-visible .feature-card { opacity: 1; transform: translateY(0) !important; }
    .showcase-scroll-wrapper.is-visible .feature-card:nth-child(1) { transition-delay: 0.1s; }
    .showcase-scroll-wrapper.is-visible .feature-card:nth-child(2) { transition-delay: 0.25s; }
    .showcase-scroll-wrapper.is-visible .feature-card:nth-child(3) { transition-delay: 0.4s; }
    .showcase-scroll-wrapper.is-visible .feature-card:nth-child(4) { transition-delay: 0.55s; }

    .action-cta { margin-top: 20px; width: 100%; display: flex; justify-content: center; }
    .btn-main { width: 100%; max-width: 340px; text-align: center; }
  }

  @media (max-width: 768px) {
    .lookbook-section { padding: 50px 20px; }
    .ebike-interactive-wrapper { max-width: 95%; }
    .hero-img { max-height: 250px; object-fit: contain; }
    .cards-responsive-container { grid-template-columns: 1fr; gap: 16px; }
    .feature-card { padding: 14px; border-radius: 16px; }
  }
</style>