---
// src/components/WhatsAppWidget.astro

// Inserisci il numero di telefono (senza il + davanti, comprensivo di prefisso internazionale 39)
const phoneNumber = "393711889651";
// Messaggio preimpostato che ti arriverà quando l'utente clicca
const defaultMessage = encodeURIComponent("Ciao! Vorrei avere delle informazioni riguardo al noleggio delle e-bike...");
const whatsappUrl = `https://wa.me/${phoneNumber}?text=${defaultMessage}`;
---

<a 
  href={whatsappUrl} 
  class="whatsapp-floating-btn" 
  target="_blank" 
  rel="noopener noreferrer" 
  aria-label="Contattaci su WhatsApp"
>
  <div class="whatsapp-icon-wrapper">
    <!-- SVG NATIVO OTTIMIZZATO: Eredita dinamicamente il colore tramite currentColor -->
    <svg 
      xmlns="http://www.w3.org/2000/svg" 
      viewBox="0 0 448 512" 
      class="whatsapp-svg"
      aria-hidden="true"
    >
      <path 
        fill="currentColor" 
        d="M380.9 97.1C339 55.1 283.2 32 223.9 32c-122.4 0-222 99.6-222 222 0 39.1 10.2 77.3 29.6 111L0 480l117.7-30.9c32.4 17.7 68.9 27 106.1 27h.1c122.3 0 224.1-99.6 224.1-222 0-59.3-25.2-115-67.1-157zm-157 341.6c-33.2 0-65.7-8.9-94-25.7l-6.7-4-69.8 18.3L72 359.2l-4.4-7c-18.5-29.4-28.2-63.3-28.2-98.2 0-101.7 82.8-184.5 184.6-184.5 49.3 0 95.6 19.2 130.4 54.1 34.8 34.9 56.2 81.2 56.1 130.5 0 101.8-84.9 184.6-186.6 184.6zm101.2-138.2c-5.5-2.8-32.8-16.2-37.9-18-5.1-1.9-8.8-2.8-12.5 2.8-3.7 5.6-14.3 18-17.6 21.8-3.2 3.7-6.5 4.2-12 1.4-32.6-16.3-54-29.1-75.5-66-5.7-9.8 5.7-9.1 16.3-30.3 1.8-3.7 .9-6.9-.5-9.7-1.4-2.8-12.5-30.1-17.1-41.2-4.5-10.8-9.1-9.3-12.5-9.5-3.2-.2-6.9-.2-10.6-.2-3.7 0-9.7 1.4-14.8 6.9-5.1 5.6-19.4 19-19.4 46.3 0 27.3 19.9 53.7 22.6 57.4 2.8 3.7 39.1 59.7 94.8 83.8 35.2 15.2 49 16.5 66.6 13.9 10.7-1.6 32.8-13.4 37.4-26.4 4.6-13 4.6-24.1 3.2-26.4-1.3-2.5-5-3.9-10.5-6.6z"
      />
    </svg>
  </div>
  <span class="whatsapp-tooltip">Chatta con noi</span>
</a>

<style>
  .whatsapp-floating-btn {
    position: fixed;
    bottom: 30px;
    right: 30px;
    z-index: 90; /* Abbastanza alto da stare sopra i contenuti, ma sotto l'header mobile aperto */
    display: flex;
    align-items: center;
    text-decoration: none;
    font-family: 'Plus Jakarta Sans', sans-serif;
    
    /* Animazione iniziale di ingresso fluida */
    opacity: 0;
    transform: translateY(20px);
    animation: floatingReady 0.6s cubic-bezier(0.16, 1, 0.3, 1) 1s forwards;
  }

  @keyframes floatingReady {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* IL CERCHIO ICONA TECH-DARK / GREEN */
  .whatsapp-icon-wrapper {
    width: 56px;
    height: 56px;
    background-color: #111111; /* Mantiene lo stile scuro tech del sito */
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #dbff9b; /* Verde acido Sambo Bike Rent */
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* Gestione geometrica e proporzioni dell'SVG nativo */
  .whatsapp-svg {
    width: 24px;
    height: 24px;
    display: block;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* EFFETTO HOVER ATTIVO */
  .whatsapp-floating-btn:hover .whatsapp-icon-wrapper {
    background-color: #dbff9b; /* Inverte i colori al passaggio del mouse */
    color: #111111;
    border-color: #dbff9b;
    transform: scale(1.08) rotate(8deg);
    box-shadow: 0 15px 35px rgba(219, 255, 155, 0.15);
  }

  /* TOOLTIP DI SUGGERIMENTO SULLA SINISTRA */
  .whatsapp-tooltip {
    position: absolute;
    right: 70px;
    background-color: #161616;
    color: #ffffff;
    padding: 8px 16px;
    border-radius: 50px;
    font-size: 0.85rem;
    font-weight: 600;
    white-space: nowrap;
    border: 1px solid rgba(255, 255, 255, 0.05);
    box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
    
    /* Stato iniziale nascosto */
    opacity: 0;
    transform: translateX(10px);
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    pointer-events: none;
  }

  .whatsapp-floating-btn:hover .whatsapp-tooltip {
    opacity: 1;
    transform: translateX(0);
  }

  /* RESPONSIVE PER SMARTPHONE */
  @media (max-width: 768px) {
    .whatsapp-floating-btn {
      bottom: 20px;
      right: 20px;
    }
    
    .whatsapp-icon-wrapper {
      width: 48px;
      height: 48px;
    }

    .whatsapp-svg {
      width: 20px;
      height: 20px;
    }

    /* Disattiviamo il tooltip su mobile per evitare overlay fastidiosi al tocco */
    .whatsapp-tooltip {
      display: none;
    }
  }
</style>