---
// Header.astro - Versione Ultra-Ottimizzata e Leggera
import logoWhite from '../images/Sambo Bike Rent Logo Orizzontale White PNG.png';
import logoBlack from '../images/Sambo Bike Rent Logo Orizzontale Black PNG.png';
const { isTransparent = true } = Astro.props;
---

<nav class={`main-header ${!isTransparent ? 'header-solid-page' : ''}`} id="globalHeader">
  <div class="header-container">
    
    <a href="/" class="brand-logo" aria-label="Sambo Bike Rent Home">
      <div class="logo-wrapper">
        <img src={logoWhite.src} alt="Sambo Bike Rent" class="logo-img logo-white" />
        <img src={logoBlack.src} alt="Sambo Bike Rent" class="logo-img logo-black" />
      </div>
    </a>

    <ul class="nav-menu" id="navMenu">
      <li class="nav-item"><a href="/#about" class="nav-link">Chi Siamo</a></li>
      <li class="nav-item"><a href="/#showcase" class="nav-link">La Bici</a></li>
      <li class="nav-item"><a href="/#offerta" class="nav-link">Cosa Ricevi</a></li>
      <li class="nav-item"><a href="/#contatti" class="nav-link">Contatti</a></li>
      <li class="nav-item"><a href="/prezzi" class="nav-link">Prezzi</a></li>
      <li class="nav-item mobile-cta-item"><a href="#contatti" class="btn-header mobile-popup-cta">Prenota Ora</a></li>
    </ul>

    <div class="header-actions">
      <a href="#contatti" class="btn-header desktop-cta">Prenota Ora</a>
      
      <button class="hamburger-btn" id="mobileMenuBtn" aria-label="Apri Menu">
        <span class="bar"></span>
        <span class="bar"></span>
        <span class="bar"></span>
      </button>
    </div>

  </div>
</nav>

<script>
  function initHeader() {
    const header = document.getElementById('globalHeader');
    const menuBtn = document.getElementById('mobileMenuBtn');
    const menu = document.getElementById('navMenu');
    const navLinks = document.querySelectorAll('.nav-link, .mobile-popup-cta');

    if (!header || !menuBtn || !menu) return;

    // 1. Gestione apertura/chiusura Menu Mobile (Puro toggle di classi)
    menuBtn.addEventListener('click', (e) => {
      e.preventDefault();
      const isOpen = menu.classList.toggle('menu-open');
      menuBtn.classList.toggle('is-active');
      
      // Gestione stato header globale
      header.classList.toggle('mobile-menu-active', isOpen);
      if (isOpen) header.classList.add('header-scrolled');

      // Il blocco dello scroll lo fa il CSS tramite questa classe sul tag html/body
      document.documentElement.classList.toggle('lock-scroll', isOpen);
    });

    // 2. Chiusura quando si clicca un link interno (Ancore)
    navLinks.forEach(link => {
      link.addEventListener('click', () => {
        menu.classList.remove('menu-open');
        menuBtn.classList.remove('is-active');
        header.classList.remove('mobile-menu-active');
        document.documentElement.classList.remove('lock-scroll');
      });
    });

    // 3. Effetto Scroll (Header compatto / a scomparsa)
    let lastScrollY = window.scrollY;
    const isSolidPage = header.classList.contains('header-solid-page');

    if (window.scrollY > 40 || isSolidPage) header.classList.add('header-scrolled');

    window.addEventListener('scroll', () => {
      if (menu.classList.contains('menu-open')) return;

      const currentScrollY = window.scrollY;

      // Mostra/Nascondi allo scroll
      if (currentScrollY > lastScrollY && currentScrollY > 80) {
        header.classList.add('header-hidden');
      } else {
        header.classList.remove('header-hidden');
      }

      // Sfondo bianco/trasparente
      if (currentScrollY > 40 || isSolidPage) {
        header.classList.add('header-scrolled');
      } else {
        header.classList.remove('header-scrolled');
      }

      lastScrollY = currentScrollY;
    }, { passive: true });
  }

  // Supporto totale al View Transitions / Router di Astro
  document.addEventListener('DOMContentLoaded', initHeader);
  document.addEventListener('astro:page-load', initHeader);
</script>

<style>
  /* ==========================================
     STRUTTURA DESKTOP BASE
     ========================================== */
  .main-header {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 99999; /* Abbassato per non lottare con iubenda */
    padding: 24px 0;
    background-color: transparent;
    transition: transform 0.3s ease, background-color 0.3s ease, padding 0.3s ease;
  }

  .main-header.header-scrolled {
    padding: 14px 0;
    background-color: rgba(255, 255, 255, 0.96) !important;
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.05);
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
  }

  .main-header.header-scrolled .nav-link { color: #111111 !important; }
  .main-header.header-scrolled .btn-header { background-color: #111111 !important; color: #ffffff !important; }
  .main-header.header-hidden { transform: translateY(-100%); }

  .header-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 40px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .main-header.header-solid-page:not(.header-scrolled) {
    background-color: #1d1d1d !important;
  }
  .main-header.header-solid-page:not(.header-scrolled) .btn-header {
    background-color: #ffffff !important;
    color: #111111 !important;
  }

  /* LOGO ANTI-GLITCH */
  .brand-logo { display: block; width: 180px; text-decoration: none; }
  .logo-wrapper { position: relative; width: 100%; height: 45px; display: flex; align-items: center; }
  .logo-img { position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: contain; transition: opacity 0.25s ease; }
  
  .logo-white { opacity: 1; }
  .logo-black { opacity: 0; }

  .main-header.header-solid-page:not(.header-scrolled) .logo-white { opacity: 1 !important; }
  .main-header.header-solid-page:not(.header-scrolled) .logo-black { opacity: 0 !important; }
  .main-header.header-scrolled .logo-white { opacity: 0 !important; }
  .main-header.header-scrolled .logo-black { opacity: 1 !important; }
  .main-header.mobile-menu-active .logo-white { opacity: 0 !important; }
  .main-header.mobile-menu-active .logo-black { opacity: 1 !important; }

  /* LINKS DESKTOP */
  .nav-menu { display: flex; align-items: center; gap: 40px; list-style: none; margin: 0; padding: 0; }
  .mobile-cta-item { display: none; }
  
  .nav-link {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 0.95rem;
    font-weight: 500;
    color: #ffffff;
    text-decoration: none;
    position: relative;
    padding: 6px 0;
    transition: color 0.25s ease;
  }

  .nav-link::after {
    content: ''; position: absolute; bottom: 0; left: 0; width: 100%; height: 1.5px; background-color: #111111; transform: scaleX(0); transition: transform 0.25s ease;
  }
  .main-header:not(.header-scrolled) .nav-link::after { background-color: #ffffff; }
  .nav-link:hover::after { transform: scaleX(1); }

  .header-actions { display: flex; align-items: center; gap: 20px; }
  
  .btn-header {
    display: inline-block;
    font-family: 'Plus Jakarta Sans', sans-serif;
    background-color: #111111;
    color: #ffffff !important;
    padding: 10px 22px;
    border-radius: 50px;
    font-weight: 600;
    font-size: 0.85rem;
    text-transform: uppercase;
    text-decoration: none;
    transition: all 0.25s ease;
  }
  .main-header:not(.header-scrolled) .btn-header { background-color: #ffffff; color: #111111 !important; }

  /* HAMBURGER */
  .hamburger-btn {
    display: none;
    flex-direction: column;
    justify-content: space-between;
    width: 22px;
    height: 14px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
  }
  .hamburger-btn .bar { width: 100%; height: 2px; background-color: #ffffff; transition: all 0.25s ease; }
  .main-header.header-scrolled .hamburger-btn .bar { background-color: #111111 !important; }

  /* ==========================================
     RESPONSIVE ED OVERLAY MOBILE
     ========================================== */
  @media (max-width: 1024px) {
    .header-container { padding: 0 24px; }
    .nav-menu { gap: 24px; }
    .brand-logo { width: 150px; }
    .logo-wrapper { height: 38px; }
  }

  @media (max-width: 768px) {
    .main-header { padding: 16px 0; }
    .hamburger-btn { display: flex; z-index: 10001; position: relative; } 
    .btn-header.desktop-cta { display: none; } 
    .brand-logo { z-index: 10001; position: relative; }

    /* L'Ancoraggio della X Mobile */
    .hamburger-btn.is-active .bar { background-color: #111111 !important; }
    .hamburger-btn.is-active .bar:nth-child(1) { transform: translateY(6px) rotate(45deg); }
    .hamburger-btn.is-active .bar:nth-child(2) { opacity: 0; }
    .hamburger-btn.is-active .bar:nth-child(3) { transform: translateY(-6px) rotate(-45deg); }

    .nav-menu {
      position: fixed;
      top: 0;
      right: 0;
      width: 100%;
      height: 100vh;
      height: 100svh; 
      background-color: rgba(255, 255, 255, 0.98);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      flex-direction: column;
      justify-content: center;
      align-items: center;
      gap: 24px;
      padding: 40px;
      box-sizing: border-box;
      transform: translateX(100%);
      transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
      z-index: 10000;
    }

    .nav-menu.menu-open { transform: translateX(0); }
    .mobile-cta-item { display: block; width: 100%; max-width: 260px; margin-top: 10px; }
    .mobile-popup-cta { width: 100%; text-align: center; padding: 14px 0; font-size: 0.9rem; }

    .nav-item {
      width: 100%;
      text-align: center;
      opacity: 0;
      transform: translateY(15px);
      transition: opacity 0.4s ease, transform 0.4s ease;
    }
    .nav-menu.menu-open .nav-item { opacity: 1; transform: translateY(0); }
    .nav-menu.menu-open .nav-item:nth-child(1) { transition-delay: 0.1s; }
    .nav-menu.menu-open .nav-item:nth-child(2) { transition-delay: 0.15s; }
    .nav-menu.menu-open .nav-item:nth-child(3) { transition-delay: 0.2s; }
    .nav-menu.menu-open .nav-item:nth-child(4) { transition-delay: 0.25s; }
    .nav-menu.menu-open .nav-item:nth-child(5) { transition-delay: 0.3s; }

    .nav-link { color: #111111 !important; font-size: 1.4rem; font-weight: 600; display: inline-block; width: 100%; }
    .nav-link::after { display: none; } 
  }

  /* ==========================================
     IL SEGRETO: BLOCCO SCROLL IN PURO CSS 
     ========================================== */
  :global(html.lock-scroll), :global(html.lock-scroll body) {
    overflow: hidden !important;
    height: 100vh !important;
    height: 100svh !important;
    
    /* Blocca la catena di scroll e il rimbalzo elastico su iOS in modo nativo */
    overscroll-behavior: contain !important; 
  }
</style>