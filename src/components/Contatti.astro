---
// Contatti.astro - Versione Tech-Dark coordinata con Incluso.astro
---

<div class="contact-scroll-wrapper" id="contatti">
  <section class="contact-section">
    
    <div class="contact-grid">
      
      <div class="contact-info-block">
        <p class="section-badge">Contatti</p>
        <h2 class="contact-title">Pronto per il <br/><span class="highlight">prossimo sentiero?</span></h2>
        
        <p class="contact-subtitle">
          Il nostro team è a tua disposizione per consigli sugli itinerari, dettagli tecnici sulle e-bike o per personalizzare il tuo noleggio.
        </p>

        <div class="info-items">
          <div class="info-item">
            <div class="icon-circle">
              <!-- SVG POSIZIONE MAPPA -->
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 384 512" class="contact-svg" aria-hidden="true">
                <path fill="currentColor" d="M215.7 499.2C267 435 384 279.4 384 192C384 86 298 0 192 0S0 86 0 192c0 87.4 117 243 168.3 307.2c12.3 15.3 35.1 15.3 47.4 0zM192 256c-35.3 0-64-28.7-64-64s28.7-64 64-64s64 28.7 64 64s-28.7 64-64 64z"/>
              </svg>
            </div>
            <div class="info-text">
              <span>Posizione</span>
              <p>Via Prova 2, San Bonifacio (VR)</p>
            </div>
          </div>

          <div class="info-item">
            <div class="icon-circle">
              <!-- SVG TELEFONO / WHATSAPP -->
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" class="contact-svg" aria-hidden="true">
                <path fill="currentColor" d="M164.9 24.6c-7.7-18.6-28-28.5-47.4-23.2l-88 24C12.1 30.2 0 46 0 64C0 311.4 200.6 512 448 512c18 0 33.8-12.1 38.6-29.5l24-88c5.3-19.4-4.6-39.7-23.2-47.4l-96-40c-16.3-6.8-35.2-2.1-46.3 11.6L304.7 368C234.3 334.7 177.3 277.7 144 207.3L193.3 167c13.7-11.2 18.4-30 11.6-46.3l-40-96z"/>
              </svg>
            </div>
            <div class="info-text">
              <span>Telefono & WhatsApp</span>
              <p>+39 351 794 5198</p>
            </div>
          </div>

          <div class="info-item">
            <div class="icon-circle">
              <!-- SVG BUSTA EMAIL -->
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" class="contact-svg" aria-hidden="true">
                <path fill="currentColor" d="M48 64C21.5 64 0 85.5 0 112c0 15.1 7.1 29.3 19.2 38.4L236.8 313.6c11.4 8.5 27 8.5 38.4 0L492.8 150.4c12.1-9.1 19.2-23.3 19.2-38.4c0-26.5-21.5-112-48-112H48zM512 175.4l-127.8 95.9c-22.3 16.7-52.2 25.4-82.3 25.4s-60-8.7-82.3-25.4L92.9 175.4C89.1 172.6 84 176 84 180.8V400c0 26.5 21.5 48 48 48H448c26.5 0 48-21.5 48-48V180.8c0-4.8-5.1-8.2-8.9-5.4z"/>
              </svg>
            </div>
            <div class="info-text">
              <span>Email</span>
              <p>info@sambobikerent.it</p>
            </div>
          </div>
        </div>

        <div class="annotation-contact">
          <span class="handwritten">Il nostro team ti risponderà il prima possibile</span>
        </div>
      </div>

      <div class="contact-form-container">
        <div class="form-card">
          <p class="form-info-text">Invia la tua richiesta di prenotazione, verificheremo la disponibilità della flotta e ti invieremo la conferma via mail/WhatsApp</p>
          <div class="embed-placeholder">
            <iframe data-tally-src="https://tally.so/embed/44OVYd?alignLeft=1&hideTitle=1&transparentBackground=1&dynamicHeight=1" loading="lazy" width="100%" height="929" frameborder="0" marginheight="0" marginwidth="0" title="Sambo Bike Rent"></iframe>
            <script>var d=document,w="https://tally.so/widgets/embed.js",v=function(){"undefined"!=typeof Tally?Tally.loadEmbeds():d.querySelectorAll("iframe[data-tally-src]:not([src])").forEach((function(e){e.src=e.dataset.tallySrc}))};if("undefined"!=typeof Tally)v();else if(d.querySelector('script[src="'+w+'"]')==null){var s=d.createElement("script");s.src=w,s.onload=v,s.onerror=v,d.body.appendChild(s);}</script>   
          </div>
        </div>
      </div>

    </div>
  </section>
</div>

<script>
  function initContactAnimation() {
    const section = document.getElementById('contatti');
    if (section) {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.15 });
      observer.observe(section);
    }
  }

  document.addEventListener('DOMContentLoaded', initContactAnimation);
  document.addEventListener('astro:page-load', initContactAnimation);
</script>

<style>
  /* ==========================================
     CONTENITORE E ZOOM INGRESSO (DARK STYLING)
     ========================================== */
  .contact-scroll-wrapper {
    width: 100%;
    background-color: #1D1D1D;
    opacity: 0;
    transform: scale(0.98);
    transition: transform 1.2s cubic-bezier(0.16, 1, 0.3, 1), opacity 1s ease-out;
    will-change: transform, opacity;
  }

  .contact-scroll-wrapper.is-visible {
    opacity: 1;
    transform: scale(1);
  }

  /* ==========================================
     LAYOUT STRUTTURALE
     ========================================== */
  .contact-section {
    padding: 140px 40px;
    max-width: 1400px;
    margin: 0 auto;
    font-family: 'Plus Jakarta Sans', sans-serif;
    box-sizing: border-box;
    color: #ffffff;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 80px;
    align-items: flex-start;
  }

  /* ==========================================
     LATO TESTI (INFO)
     ========================================== */
  .contact-info-block {
    position: sticky;
    top: 120px;
  }

  .section-badge {
    font-size: 0.75rem;
    text-transform: uppercase;
    font-weight: 700;
    letter-spacing: 2px;
    color: #dbff9b;
    border: 1px solid rgba(219, 255, 155, 0.2);
    padding: 6px 14px;
    border-radius: 50px;
    display: inline-block;
    margin-bottom: 25px;
    background: rgba(219, 255, 155, 0.03);
  }

  .contact-title {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: clamp(2.5rem, 4.5vw, 3.8rem);
    font-weight: 600;
    line-height: 1.1;
    color: #ffffff;
    margin: 0 0 30px 0;
    letter-spacing: -0.04em;
  }

  .highlight {
    font-style: italic;
    font-weight: 400;
    color: #ffffff;
  }

  .contact-subtitle {
    font-size: 1.1rem;
    line-height: 1.6;
    color: #888888;
    margin: 0 0 50px 0;
    max-width: 500px;
  }

  .info-items {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .info-item {
    display: flex;
    align-items: center;
    gap: 20px;
  }

  /* STRUTTURA DEL CERCHIO PER L'ICONA */
  .icon-circle {
    width: 44px;
    height: 44px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #dbff9b;
    transition: all 0.3s ease;
    flex-shrink: 0;
  }

  /* DIMENSIONAMENTO DI PRECISIONE PER GLI SVG INLINE */
  .contact-svg {
    width: 16px;
    height: 16px;
    display: block;
  }

  .info-item:hover .icon-circle {
    background: #dbff9b;
    color: #111111;
    border-color: #dbff9b;
    box-shadow: 0 0 20px rgba(219, 255, 155, 0.2);
  }

  .info-text span {
    display: block;
    font-size: 0.75rem;
    text-transform: uppercase;
    color: #666666;
    font-weight: 700;
    letter-spacing: 1px;
  }

  .info-text p {
    font-size: 1.1rem;
    font-weight: 500;
    color: #ffffff;
    margin: 4px 0 0 0;
  }

  .annotation-contact {
    margin-top: 50px;
    display: flex;
    align-items: center;
    gap: 15px;
  }

  .handwritten {
    font-family: 'Caveat', cursive;
    font-size: 1.7rem;
    color: #dbff9b;
    font-weight: 500;
  }

  /* ==========================================
     LATO FORM (CARD)
     ========================================== */
  .contact-form-container {
    width: 100%;
    box-sizing: border-box;
  }

  .form-card {
    background: #161616;
    padding: 48px;
    border-radius: 24px;
    box-shadow: 0 30px 60px rgba(0,0,0,0.2);
    border: 1px solid rgba(255,255,255,0.05);
    box-sizing: border-box;
    
    opacity: 0;
    transform: translateY(30px);
    transition: transform 1s cubic-bezier(0.16, 1, 0.3, 1) 0.2s, opacity 0.8s ease-out 0.2s;
  }

  .is-visible .form-card {
    opacity: 1;
    transform: translateY(0);
  }

  .form-info-text {
    color: #dbff9b;
    font-size: 0.95rem;
    line-height: 1.5;
    font-weight: 500;
    margin: 0 0 30px 0;
    padding-bottom: 20px;
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }

  /* ==========================================
     MEDIA QUERIES - RESPONSIVE DI PRECISIONE
     ========================================== */
  @media (max-width: 1200px) {
    .contact-grid { gap: 40px; }
    .form-card { padding: 32px; }
  }

  @media (max-width: 1024px) {
    .contact-section { padding: 100px 32px; }
    .contact-grid { grid-template-columns: 1fr; gap: 60px; }
    .contact-info-block {
      position: relative;
      top: 0;
      text-align: center;
      display: flex;
      flex-direction: column;
      align-items: center;
    }
    .contact-subtitle { max-width: 650px; margin-bottom: 40px; }
    .info-items {
      flex-direction: row;
      justify-content: center;
      flex-wrap: wrap;
      gap: 40px;
      width: 100%;
    }
    .info-item { text-align: left; }
    .annotation-contact { margin-top: 40px; }
  }

  @media (max-width: 768px) {
    .contact-section { padding: 80px 20px; }
    .contact-title { font-size: 2.4rem; }
    .info-items {
      flex-direction: column;
      align-items: flex-start;
      gap: 24px;
      max-width: 320px;
      margin: 0 auto;
    }
    .info-item { width: 100%; }
    .form-card {
      padding: 24px;
      border-radius: 20px;
      opacity: 1 !important;
      transform: none !important;
    }
    .form-info-text { font-size: 0.9rem; margin-bottom: 20px; }
    .contact-scroll-wrapper { transform: none !important; opacity: 1 !important; }
  }
</style>