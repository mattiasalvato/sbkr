---
// Quarta Sezione: Cosa è incluso nel Noleggio (Stile Tech Grid Avanzato con Overlapping Effect)
---

<section class="incluso-section" id="offerta">
  <div class="incluso-header">
    <p class="section-badge">Zero Pensieri</p>
    <h2 class="section-title">Built for <span class="highlight-text">adventure</span></h2>
    <p class="section-subtitle">
      Ogni noleggio include tutto il necessario per garantire la massima sicurezza e libertà sui sentieri. Nessun costo nascosto, solo pura esplorazione.
    </p>
  </div>

  <div class="tech-grid">
    
    <div class="grid-item fade-in-item">
      <div class="item-icon ico-helmet">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
          <path d="M2 12C2 6.48 6.48 2 12 2s10 4.48 10 10v2H2v-2Z" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M5 14v3a3 3 0 0 0 3 3h8a3 3 0 0 0 3-3v-3" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M12 2v8" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
      <h3 class="item-title">Casco di Sicurezza</h3>
      <p class="item-description">Modello omologato ad alta protezione, igienizzato dopo ogni utilizzo.</p>
    </div>

    <div class="grid-item fade-in-item">
      <div class="item-icon ico-shield">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
      <h3 class="item-title">Assicurazione RC</h3>
      <p class="item-description">Copertura contra danni a terzi inclusa per tutta la durata del noleggio.</p>
    </div>

    <div class="grid-item fade-in-item">
      <div class="item-icon ico-wrench">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
          <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 0-7.94-7.94L3.6 11.46a4.5 4.5 0 0 0 6.36 6.36l3.8-3.8a1 1 0 0 0 0-1.4l-1.6-1.6a1 1 0 0 0-1.4 0l-4 4a2.5 2.5 0 0 1-3.54-3.54l9.4-9.4a4 4 0 0 1 5.66 5.66l-3.6 3.6Z" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
      <h3 class="item-title">Kit Fast Repair</h3>
      <p class="item-description">Borsello sottosella con camera d'aria, cacciagomme e pompa compatta.</p>
    </div>

    <div class="grid-item fade-in-item">
      <div class="item-icon ico-lock">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
          <rect x="3" y="11" width="18" height="11" rx="2" ry="2" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M7 11V7a5 5 0 0 1 10 0v4" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
      <h3 class="item-title">Lucchetto Antifurto</h3>
      <p class="item-description">Chiusura in acciaio temperato ad alta sicurezza per le tue soste.</p>
    </div>

    <div class="grid-item fade-in-item">
      <div class="item-icon ico-map">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
          <polygon points="3 6 9 3 15 6 21 3 21 18 15 21 9 18 3 21" stroke-linecap="round" stroke-linejoin="round"/>
          <line x1="9" y1="3" x2="9" y2="18" stroke-linecap="round" stroke-linejoin="round"/>
          <line x1="15" y1="6" x2="15" y2="21" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
      <h3 class="item-title">Tracce GPS (.gpx)</h3>
      <p class="item-description">Accesso esclusivo alle mappe digitali e ai migliori itinerari del territorio.</p>
    </div>

    <div class="grid-item fade-in-item">
      <div class="item-icon ico-phone">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
      <h3 class="item-title">Assistenza 24/7</h3>
      <p class="item-description">Supporto telefonico e recupero tecnico sul percorso in caso di guasto grave.</p>
    </div>

  </div>
</section>

<script>
  function initInclusoAnimation() {
    const section = document.getElementById('offerta');
    const items = document.querySelectorAll('.fade-in-item');

    if (section) {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            items.forEach((item, index) => {
              setTimeout(() => {
                item.classList.add('is-visible');
              }, index * 100); 
            });
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.15, rootMargin: '0px 0px -40px 0px' });

      observer.observe(section);
    }
  }

  document.addEventListener('DOMContentLoaded', initInclusoAnimation);
  document.addEventListener('astro:page-load', initInclusoAnimation);
</script>

<style>
  /* ==========================================
     STILE OVERLAP SCROLLER (REFOK STYLE MATT)
     ========================================== */
  .incluso-section {
    /* 👇 ABILITAZIONE DELLO STICKY STACKING: Vince su Showcase (z-index: 1) e si aggancia a top 0 */
    position: sticky;
    top: 0;
    height: 100vh;
    min-height: 100vh;
    z-index: 2; 
    overflow-y: auto; /* Permette lo scroll nativo se i testi/griglia sporgono sui monitor piccoli */

    background-color: #1d1d1d; 
    color: #ffffff;
    padding: 80px 60px; /* Ridotto per centrare perfettamente i blocchi in 100vh */
    font-family: 'Plus Jakarta Sans', sans-serif;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 40px; /* Compatto ed elegante */
    box-shadow: 0 -40px 80px rgba(0, 0, 0, 0.25);
  }

  /* ==========================================
     LAYOUT INTESTAZIONE
     ========================================== */
  .incluso-header {
    max-width: 800px;
  }

  .section-badge {
    color: #dbff9b; 
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    font-weight: 600;
    margin: 0 0 12px 0;
  }

  .section-title {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 3.5rem;
    font-weight: 700;
    line-height: 1.1;
    margin: 0 0 15px 0;
    letter-spacing: -0.03em;
  }

  .highlight-text {
    color: #dbff9b;
    font-weight: 400;
    font-style: italic;
  }

  .section-subtitle {
    font-size: 1.1rem;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.8);
    margin: 0;
  }

  /* ==========================================
     LA GRIGLIA CON BORDI SOTTILI TECH
     ========================================== */
  .tech-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    border-left: 1px solid rgba(255, 255, 255, 0.08);
  }

  .grid-item {
    position: relative;
    padding: 45px 35px; /* Ottimizzato per schermi laptop standard */
    border-right: 1px solid rgba(255, 255, 255, 0.08);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    display: flex;
    flex-direction: column;
    gap: 15px;
    background-color: transparent;
    
    opacity: 0;
    transform: translateY(30px);
    will-change: transform, opacity;
    transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), 
                transform 0.8s cubic-bezier(0.16, 1, 0.3, 1), 
                background-color 0.4s ease;
  }

  .grid-item.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .grid-item:hover {
    background-color: rgba(255, 255, 255, 0.02);
  }

  /* ==========================================
     STILE FAVICON / ICONE E MICRO-INTERAZIONI
     ========================================== */
  .item-icon {
    width: 24px;
    height: 24px;
    color: #dbff9b;
    transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    will-change: transform;
  }

  .item-icon svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .grid-item:hover .ico-helmet { transform: translateY(-4px) rotate(-5deg); }
  .grid-item:hover .ico-shield { transform: scale(1.15); }
  .grid-item:hover .ico-wrench { transform: rotate(45deg); }
  .grid-item:hover .ico-lock   { transform: translateY(-3px); }
  .grid-item:hover .ico-map    { transform: scaleX(-1) rotate(5deg); }
  .grid-item:hover .ico-phone  { transform: rotate(-15deg) scale(1.1); }

  .item-title {
    font-size: 1.25rem;
    font-weight: 600;
    margin: 0;
    letter-spacing: -0.01em;
  }

  .item-description {
    font-size: 0.9rem;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.7);
    margin: 0;
  }

  /* ==========================================
     RESPONSIVE DI PRECISIONE 
     ========================================== */
  @media (max-width: 1120px) {
    .grid-item { padding: 35px 25px; }
  }

  @media (max-width: 1024px) {
    .incluso-section {
    position: sticky !important; /* 👈 Riattiviamo lo sticky su mobile */
    top: 0;
    height: 100dvh !important;     /* 👈 Altezza dinamica stabile */
    min-height: 100dvh !important;
    padding: 40px 24px;          /* Padding compatto anti-overflow */
    gap: 30px;
  }
    .section-title { font-size: 2.8rem; }
    .tech-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 768px) {
    .incluso-section {
    padding: 40px 20px;
    gap: 20px;
  }
    .section-title { font-size: 2.2rem; }
    .tech-grid {
    /* Consiglio extra: se hai molto testo, usa l'auto-scroll interno alla griglia */
    max-height: 60dvh;
    overflow-y: auto; 
  }
    .grid-item {
      padding: 30px 15px;
      gap: 12px;
      transform: translateY(20px);
    }
    .item-title { font-size: 1.15rem; }
  }
</style>